    "lld:remove": {
      "name": "lld:remove",
      "description": "Detatch lambda-live-debugger from deployed lambdas defined in the lldebugger.config.ts file",
      "env": {
        "PERSONAL_STACK_NAME": "$(whoami | tr -dc '[:alnum:]-' | cut -c 1-10)"
      },
      "steps": [
