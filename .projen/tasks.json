        }
      ]
    },
    "lld:vscode-snippet": {
      "name": "lld:vscode-snippet",
      "description": "Show .vscode/launch.json configuration for lambda-live-debugger",
      "steps": [
        {
          "exec": "echo 'Add this to .vscode/launch.json'\necho ''\necho '{\n  \"version\": \"0.2.0\",\n  \"configurations\": [\n    {\n      \"name\": \"Lambda Live Debugger\",\n      \"type\": \"node\",\n      \"request\": \"launch\",\n      \"runtimeExecutable\": \"${workspaceFolder}/node_modules/.bin/lld\",\n      \"runtimeArgs\": [],\n      \"console\": \"integratedTerminal\",\n      \"skipFiles\": [\"<node_internals>/**\"],\n      \"env\": {\n        \"PERSONAL_STACK_NAME\": \"${env:USER}\"\n      }\n    }\n  ]\n}'"
        }
      ]
    },
    "notify-multitudes:prod": {
      "name": "notify-multitudes:prod",
      "steps": [
        {
          "exec": "if [ -n \"$MULTITUDES_TOKEN\" ]; then curl --request POST --url \"https://api.developer.multitudes.co/deployments\" -H \"Content-Type: application/json\" -H \"Authorization: $MULTITUDES_TOKEN\" --data \"{\\\"commitSha\\\": \\\"$CIRCLE_SHA1\\\", \\\"environmentName\\\":\\\"prod\\\"}\"; fi"
        }
      ]
    },
