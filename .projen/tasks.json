    "update-event-studio-service:dev": {
      "name": "update-event-studio-service:dev",
      "steps": [
        {
          "exec": "apiid=$(aws apigateway get-rest-apis --profile veho-dev --region us-east-1 --query \"items[?name=='event-studio-internal']|[0].id\" | tr -d '\"')\nif [ \"null\" = \"${apiid}\" ] || [ \"\" = \"${apiid}\" ]; then \n  echo \"event studio api not found!\"\nelse\n  resourceid=$(aws apigateway get-resources --profile veho-dev --region us-east-1 --rest-api-id $apiid --query \"items[?path=='/services']|[0].id\" | tr -d '\"')\n  if [ \"null\" = \"${resourceid}\" ] || [ \"\" = \"${apiid}\" ]; then\n      echo \"event studio services resource not found!\"\n  else\n    aws apigateway test-invoke-method --profile veho-dev --rest-api-id $apiid --resource-id $resourceid --http-method POST --body \"{\\\"repoName\\\":\\\"veho-technologies/webhook-transformer-service\\\",\\\"serviceName\\\":\\\"webhook-transformer-service\\\"}\"\n  fi\nfi"
        }
      ]
    },
    "update-event-studio-service:prod": {
      "name": "update-event-studio-service:prod",
      "steps": [
        {
          "exec": "apiid=$(aws apigateway get-rest-apis --profile veho-prod --region us-east-1 --query \"items[?name=='event-studio-internal']|[0].id\" | tr -d '\"')\nif [ \"null\" = \"${apiid}\" ] || [ \"\" = \"${apiid}\" ]; then \n  echo \"event studio api not found!\"\nelse\n  resourceid=$(aws apigateway get-resources --profile veho-prod --region us-east-1 --rest-api-id $apiid --query \"items[?path=='/services']|[0].id\" | tr -d '\"')\n  if [ \"null\" = \"${resourceid}\" ] || [ \"\" = \"${apiid}\" ]; then\n      echo \"event studio services resource not found!\"\n  else\n    aws apigateway test-invoke-method --profile veho-prod --rest-api-id $apiid --resource-id $resourceid --http-method POST --body \"{\\\"repoName\\\":\\\"veho-technologies/webhook-transformer-service\\\",\\\"serviceName\\\":\\\"webhook-transformer-service\\\"}\"\n  fi\nfi"
        }
      ]
    },
    "update-event-studio-service:sandbox": {
      "name": "update-event-studio-service:sandbox",
